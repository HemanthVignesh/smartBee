# ── Smart Bee — environment variables ─────────────────────────────────────────
# Copy this file to .env and fill in the values.  Never commit .env.

# ── Core ──────────────────────────────────────────────────────────────────────
APP_NAME=Smart BEE
DEBUG=true
DATABASE_URL=sqlite:///./smartbee.db
FRONTEND_URL=http://localhost:5173

# ── JWT (NEW) ─────────────────────────────────────────────────────────────────
# Generate with:  python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=CHANGE_ME_to_a_64_char_random_hex_string
JWT_EXPIRE_MINUTES=10080   # 7 days

# ── Google OAuth 2.0 (NEW) ────────────────────────────────────────────────────
# 1. Go to https://console.cloud.google.com
# 2. Create a project → Enable Gmail API + Google Calendar API + Google People API
# 3. APIs & Services → Credentials → Create OAuth 2.0 Client ID (type: Web application)
# 4. Authorised redirect URIs: http://localhost:8000/api/v1/auth/google/callback
# 5. Copy Client ID and Client Secret below:
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# ── AI / LLM ─────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
GEMINI_API_KEY=

# ── Gmail (legacy file-based flow — no longer needed when OAuth is configured)
# GMAIL_CREDENTIALS_FILE=credentials.json
# GMAIL_TOKEN_FILE=token.pickle
