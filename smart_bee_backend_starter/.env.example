# Smart BEE Backend Configuration Example
# Copy this file to .env and fill in your details.

# App Settings
APP_NAME=Smart BEE
DEBUG=True
ENV=development

# Database
DATABASE_URL=sqlite:///./smartbee.db

# Gmail API (path relative to smart_bee_backend_starter root directory)
GMAIL_CREDENTIALS_FILE=app/config/credentials.json
GMAIL_TOKEN_FILE=app/config/token.pickle

# OpenAI (Optional - for AI features, e.g. "sk-proj-...")
OPENAI_API_KEY=

# Gemini (Optional - for AI features, e.g. "AIzaSy...")
GEMINI_API_KEY=

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Server Settings
HOST=0.0.0.0
PORT=8000
