# ─────────────────────────────────────────────────────────────────────
# SmartBee Backend — Environment Configuration
# Copy this to .env and fill in your values.  Never commit .env to git.
# ─────────────────────────────────────────────────────────────────────

# App
APP_ENV=development        # development | production
DEBUG=true
FRONTEND_URL=http://localhost:5173

# ── Database ──────────────────────────────────────────────────────────
# Local dev — SQLite (zero config, auto-created):
DATABASE_URL=sqlite+aiosqlite:///./smartbee.db

# Production — swap to PostgreSQL (Neon, Supabase, Railway, RDS, etc.):
# DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/smartbee

# ── AI Keys ───────────────────────────────────────────────────────────
# Set these here (server-side only) OR enter them via the Settings UI.
GEMINI_API_KEY=
OPENAI_API_KEY=

# ── Security ──────────────────────────────────────────────────────────
# Generate with:  openssl rand -hex 32
SECRET_KEY=change-me-generate-a-real-secret

# ── Rate limiting (requests per IP per 60-second window) ──────────────
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_GENERAL=60      # reads — inbox, analytics, settings
RATE_LIMIT_AI=10           # AI calls — costs money per request
RATE_LIMIT_SENSITIVE=5     # Gmail sync — heavy external + DB ops
